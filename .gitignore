# .gitignore - Git ignore rules for CediApp

# Environment variables
.env
.env.local
.env.*.local

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.classpath
*.sublime-workspace

# Node modules (if using npm scripts)
node_modules/
# Note: Lock files (package-lock.json, yarn.lock, pnpm-lock.yaml) should be committed
# to ensure consistent dependency resolution across environments

# Build outputs
dist/
build/
*.map

# OS-specific files
Thumbs.db
.DS_Store
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
tmp/
temp/
*.tmp

# Supabase local development (if applicable)
supabase/.branches/
supabase/.temp/
