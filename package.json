{
  "name": "cedi-app",
  "version": "1.0.0",
  "description": "Unique ID decentralized cedi token",
  "main": "index.html",
  "scripts": {
    "dev": "serve . -l 8000",
    "build": "echo 'Static site - no build needed'",
    "start": "serve . -l 8080",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "cypress run",
    "lint": "eslint . --ext .html,.js",
    "security:audit": "npm audit",
    "security:check": "npm audit fix",
    "deploy:vercel": "vercel deploy",
    "deploy:netlify": "netlify deploy --prod",
    "deploy:do": "doctl apps create-deployment",
    "deploy:docker": "docker build -t cedi-app . && docker push YOUR_USERNAME/cedi-app:latest",
    "docker:run": "docker-compose up -d",
    "docker:stop": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "keywords": [
    "ghana",
    "unique-id",
    "blockchain",
    "fintech",
    "cedi",
    "banking"
  ],
  "author": "smtnewgh-blip",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.0",
    "cypress": "^13.6.0",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "netlify-cli": "^17.2.0",
    "playwright": "^1.40.0",
    "prettier": "^3.0.0",
    "serve": "^14.2.0",
    "vercel": "^32.4.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/smtnewgh-blip/Cedi-app.git"
  },
  "bugs": {
    "url": "https://github.com/smtnewgh-blip/Cedi-app/issues"
  },
  "homepage": "https://github.com/smtnewgh-blip/Cedi-app#readme"
}
